# Copy this file to .env.local for local native dev-client testing.
#
# Get the real invitation URL from https://indicio-tech.github.io/mediator/
# by using "Copy Invitation URL". Do not use the page URL itself.
EXPO_PUBLIC_MEDIATOR_INVITATION_URL=

# Indicio public mediator invitations include a WebSocket endpoint. Keep this
# implicit mode unless you switch to a mediator that requires explicit pickup.
EXPO_PUBLIC_MEDIATOR_PICKUP_STRATEGY=Implicit

# Public admin host that issues credential activation links. Android App Links
# verify this host against https://<host>/.well-known/assetlinks.json.
EXPO_PUBLIC_UNIFY_ACTIVATION_HOST=localhost
EXPO_PUBLIC_UNIFY_ACTIVATION_HOSTS=localhost,10.0.2.2
